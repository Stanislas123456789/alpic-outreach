# Google OAuth (same credentials as pipeline)
GMAIL_CLIENT_ID=997883387845-lafhmi0dr5uqqf7ddg1cakkcn30dok2h.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=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

# Google Sheets (for pipeline)
GOOGLE_SHEET_ID=1OviVTObkxp39uCj_kQmRe8M7aqloDvPLq162oH63nQI
GOOGLE_SHEET_TAB=TRAVEL
GOOGLE_SERVICE_ACCOUNT_EMAIL=alpic-sheets@vertical-task-477616-a6.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Server
PORT=4001

# OAuth redirect URI — must be registered in Google Cloud Console
# Dev:  http://localhost:4001/api/senders/auth/callback
# Prod: https://YOUR_RAILWAY_URL/api/senders/auth/callback
OAUTH_REDIRECT_URI=http://localhost:4001/api/senders/auth/callback

# Dashboard URL (for post-OAuth redirects)
# Dev:  http://localhost:3001
# Prod: https://YOUR_VERCEL_URL
DASHBOARD_URL=http://localhost:3001

# Set to true on Railway to run pipeline cron jobs inside the API process
START_PIPELINE_CRON=false

# Tracking pixel server URL
TRACKING_BASE_URL=https://track.alpic.ai

# Pipeline config
MIN_DELAY_SECONDS=90
MAX_DELAY_SECONDS=180
DRY_RUN=false
